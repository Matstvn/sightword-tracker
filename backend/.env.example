# Example environment variables for the backend service
# Copy to `.env` and fill values for your environment.

# App
APP_NAME="Sight Word Tracker API"
DEBUG=false

# CORS - comma-separated origins allowed to access the API (no spaces)
# Set this to your deployed domain(s), e.g. https://example.com
ALLOWED_ORIGINS=http://localhost:8000

# Force HTTPS redirects in production
FORCE_HTTPS=false

# Database (MySQL example)
DB_HOST=localhost
DB_PORT=3306
DB_USER=cloyd
DB_PASSWORD=813617
DB_NAME=sightword_db

# Optional: set a shared password to gate mutating API requests
# When set, POST/PUT/PATCH/DELETE requests to `/api/*` must include the
# header `X-SHARED-PASSWORD: <value>` or the `?shared_password=<value>` query param.
SHARED_PASSWORD=126817

# You can also set other environment-specific options here (SENTRY_DSN, SECRET_KEY, etc.)
